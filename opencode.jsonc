{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./plugins/romantasy.mjs",
    "./plugins/litrpg.mjs",
    "./plugins/dev.mjs",
    "./plugins/srl.mjs"
  ],
  "agent": {
    "R-Plan": {
      "description": "Orchestrates the planning pipeline. Guides the user through the 10-section architecture questionnaire by delegating to specialist sub-agents. Invoke with a book idea to begin.",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "{file:./prompts/R-Plan.txt}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "deny",
        "task": {
          "*": "allow",
          "R-Plan": "deny"
        }
      }
    },
    "R-Lore": {
      "description": "World-building specialist. Builds setting, factions, magic systems, and romantic constraints.",
      "mode": "subagent",
      "temperature": 0.3,
      "prompt": "{file:./prompts/R-Lore.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Character": {
      "description": "Character creation specialist. Designs core wounds, archetypes, voice tables, and character arcs.",
      "mode": "subagent",
      "temperature": 0.3,
      "prompt": "{file:./prompts/R-Character.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Structure": {
      "description": "Structural planner. Maps chapter beat map, hook escalation, act architecture, and density specification.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./prompts/R-Structure.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Intimacy": {
      "description": "Romance arc designer. Specifies touch map, dialogue register map, intimacy escalation, decoy scenes, and quotable moments.",
      "mode": "subagent",
      "temperature": 0.3,
      "prompt": "{file:./prompts/R-Intimacy.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Market": {
      "description": "Commercial viability specialist. Selects tropes, positions spice level, writes blurb, identifies comparable titles.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:./prompts/R-Market.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Write": {
      "description": "Orchestrates the writing pipeline. Delegates chapter drafting to specialist sub-agents through a 5-pass process: abundance, dialogue polish, interiority expansion, ruthless cut, continuity lock.",
      "mode": "primary",
      "temperature": 0.2,
      "prompt": "{file:./prompts/R-Write.txt}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "deny",
        "task": {
          "*": "allow",
          "R-Write": "deny"
        }
      }
    },
    "R-Scene": {
      "description": "Abundance writer. Writes chapters at 150% of target word count with full heat and no self-editing.",
      "mode": "subagent",
      "temperature": 0.4,
      "prompt": "{file:./prompts/R-Scene.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Dialogue": {
      "description": "Dialogue enrichment specialist. Applies 8 mechanisms, body beats, subtext layers, and proximity principles to all exchanges.",
      "mode": "subagent",
      "temperature": 0.4,
      "prompt": "{file:./prompts/R-Dialogue.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Texture": {
      "description": "Texture specialist. Adds interiority moments, reaction delays, and sensory transition texture to chapters.",
      "mode": "subagent",
      "temperature": 0.3,
      "prompt": "{file:./prompts/R-Texture.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Refine": {
      "description": "Ruthless cutter. Cuts chapters to target word count while preserving texture. Enforces style fingerprint density targets.",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "{file:./prompts/R-Refine.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Sentry": {
      "description": "Continuity enforcer. Updates romance state tracker, verifies hooks, checks timeline and magic rule consistency.",
      "mode": "subagent",
      "temperature": 0.0,
      "prompt": "{file:./prompts/R-Sentry.txt}",
      "permission": {
        "read": "allow",
        "write": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Proof": {
      "description": "Orchestrates the proofing pipeline. Runs multi-pass multi-agent editing: micro-scalpel, macro-architect, dimensional linter, recursive paradox check. Invoke with 'proof <path>' or 'proof-full <dir>'.",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "{file:./prompts/R-Proof.txt}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "scripts/compute-delta.sh *": "allow",
          "*": "ask"
        },
        "task": {
          "*": "allow",
          "R-Proof": "deny"
        }
      }
    },
    "R-Pedant": {
      "description": "Grammar and syntax enforcer. Zero-tolerance for orthographic errors, comma splices, and dangling modifiers.",
      "mode": "subagent",
      "temperature": 0.0,
      "prompt": "{file:./prompts/R-Pedant.txt}",
      "permission": {
        "read": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Logic": {
      "description": "Causal integrity auditor. Rebuilds timelines, flags fallacies, checks spatial and magic system consistency.",
