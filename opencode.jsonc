      "description": "Prosody and rhythm analyst. Hunts AI-sounding text patterns: uniform cadence, excessive transitions, cliche triads, low burstiness.",
      "mode": "subagent",
      "temperature": 0.4,
      "prompt": "{file:./prompts/R-Poet.txt}",
      "permission": {
        "read": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Threads": {
      "description": "Narrative thread tracker. Monitors McGuffins, Chekhov's Guns, character arcs, and expository dialogue.",
      "mode": "subagent",
      "temperature": 0.2,
      "prompt": "{file:./prompts/R-Threads.txt}",
      "permission": {
        "read": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
    "R-Skeptic": {
      "description": "Devil's advocate. Reads with active hostility. Challenges every paragraph's necessity, character motivation, and scene purpose.",
      "mode": "subagent",
      "temperature": 0.5,
      "prompt": "{file:./prompts/R-Skeptic.txt}",
      "permission": {
        "read": "allow",
        "task": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny"
      }
    },
