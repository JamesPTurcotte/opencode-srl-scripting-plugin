      "temperature": 0.1,
      "prompt": "{file:./prompts/R-Sell.txt}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "deny",
        "task": {
          "*": "allow",
          "R-Sell": "deny"
        }
      }
    },
